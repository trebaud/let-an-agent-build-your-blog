{
  "name": "pagewright",
  "version": "0.1.0",
  "description": "A small, typed static site generator where content is a contract and presentation is fully agent-customizable.",
  "module": "core/index.ts",
  "type": "module",
  "license": "MIT",
  "devDependencies": {
    "bun-types": "^1.3.9"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "marked": "^17.0.1",
    "marked-highlight": "^2.2.3"
  },
  "scripts": {
    "build": "rm -rf public && bun core/index.ts",
    "dev": "bun core/dev.ts",
    "typecheck": "bunx tsc --noEmit"
  }
}
